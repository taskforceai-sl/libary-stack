{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@jingles/shared": ["packages/shared/src"],
      "@jingles/shared/*": ["packages/shared/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "packages/web", "packages/electron"]
}
