generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String
  vendorId     String?  @map("vendor_id")
  createdAt    DateTime @default(now()) @map("created_at")
  isActive     Boolean  @default(true) @map("is_active")

  vendor                 Vendor?                @relation(fields: [vendorId], references: [id])
  inventoryRecords       InventoryRecord[]
  inventoryEvents        InventoryEvent[]
  grns                   GRN[]
  inspectionRecords      InspectionRecord[]
  auditLogs              AuditLog[]
  stockTransfersCreated  StockTransfer[]        @relation("StockTransferCreator")
  stockTransfersApproved StockTransfer[]        @relation("StockTransferApprover")

  @@map("users")
}

model Vendor {
  id           String   @id @default(uuid())
  name         String
  contactEmail String   @map("contact_email")
  contactPhone String?  @map("contact_phone")
  address      String?
  type         String   @default("Vendor") @map("type")
  website      String?
  taxId        String?  @map("tax_id")
  paymentTerms String?  @map("payment_terms")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  isActive     Boolean  @default(true) @map("is_active")

  users User[]
  skus  SKU[]
  grns  GRN[]

  @@map("vendors")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  parentId    String?   @map("parent_id")
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  skus     SKU[]

  @@map("categories")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now()) @map("created_at")

  skus SKUTag[]

  @@map("tags")
}

model UnitOfMeasureModel {
  id           String   @id @default(uuid())
  name         String   @unique
  abbreviation String
  baseUnit     String?  @map("base_unit")
  conversionFactor Float? @map("conversion_factor")
  type         String
  isActive     Boolean  @default(true) @map("is_active")
  isSystem     Boolean  @default(false) @map("is_system")
  createdAt    DateTime @default(now()) @map("created_at")

  skus SKU[]

  @@map("units_of_measure")
}

model Branch {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  address     String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true) @map("is_active")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")

  floors                Floor[]
  stockTransfersFrom    StockTransfer[] @relation("StockTransferFrom")
  stockTransfersTo      StockTransfer[] @relation("StockTransferTo")

  @@map("branches")
}

model SKU {
  id              String   @id @default(uuid())
  skuCode         String   @unique @map("sku_code")
  name            String
  description     String?
  categoryId      String?  @map("category_id")
  vendorId        String   @map("vendor_id")
  unitOfMeasureId String?  @map("unit_of_measure_id")
  unitOfMeasure   String   @map("unit_of_measure")
  conversionRules Json?    @map("conversion_rules")
  dimensions      Json?
  isFragile       Boolean  @default(false) @map("is_fragile")
  maxStackHeight  Float?   @map("max_stack_height")
  batchPricing    Json?    @map("batch_pricing")
  lowStockThreshold Int?   @map("low_stock_threshold")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  vendor           Vendor              @relation(fields: [vendorId], references: [id])
  category         Category?           @relation(fields: [categoryId], references: [id])
  unitModel        UnitOfMeasureModel? @relation(fields: [unitOfMeasureId], references: [id])
  inventoryRecords InventoryRecord[]
  grnLines         GRNLine[]
  images           ProductImage[]
  barcodes         ProductBarcode[]
  tags             SKUTag[]
  skuAttributes    SKUAttribute[]
  variants         SKUVariant[]

  @@map("skus")
}

model SKUTag {
  skuId String @map("sku_id")
  tagId String @map("tag_id")

  sku SKU @relation(fields: [skuId], references: [id], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([skuId, tagId])
  @@map("sku_tags")
}

// ── Global Attribute System ────────────────────────────────

model Attribute {
  id            String   @id @default(uuid())
  name          String   @unique
  type          String   @default("dropdown") // dropdown | text | numeric | boolean
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  values         AttributeValue[]
  skuAttributes  SKUAttribute[]
  variantValues  SKUVariantValue[]

  @@map("attributes")
}

model AttributeValue {
  id          String   @id @default(uuid())
  attributeId String   @map("attribute_id")
  value       String
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  attribute     Attribute         @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variantValues SKUVariantValue[]
  skuAttributeValues SKUAttributeValue[]

  @@unique([attributeId, value])
  @@map("attribute_values")
}

// Which attributes are assigned to a product (SKU)
model SKUAttribute {
  id          String @id @default(uuid())
  skuId       String @map("sku_id")
  attributeId String @map("attribute_id")

  sku            SKU                  @relation(fields: [skuId], references: [id], onDelete: Cascade)
  attribute      Attribute            @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  selectedValues SKUAttributeValue[]

  @@unique([skuId, attributeId])
  @@map("sku_attributes")
}

// Which specific values of each attribute are selected for a product
model SKUAttributeValue {
  skuAttributeId   String @map("sku_attribute_id")
  attributeValueId String @map("attribute_value_id")

  skuAttribute   SKUAttribute   @relation(fields: [skuAttributeId], references: [id], onDelete: Cascade)
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@id([skuAttributeId, attributeValueId])
  @@map("sku_attribute_values")
}

// Each SKU variant = a unique combination of attribute values
model SKUVariant {
  id          String   @id @default(uuid())
  skuId       String   @map("sku_id")
  variantCode String   @unique @map("variant_code")
  name        String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sku              SKU               @relation(fields: [skuId], references: [id], onDelete: Cascade)
  attributeValues  SKUVariantValue[]
  inventoryRecords InventoryRecord[]
  grnLines         GRNLine[]

  @@map("sku_variants")
}

// Links a variant to its specific attribute values (one row per attribute)
model SKUVariantValue {
  variantId        String @map("variant_id")
  attributeId      String @map("attribute_id")
  attributeValueId String @map("attribute_value_id")

  variant        SKUVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute      Attribute      @relation(fields: [attributeId], references: [id])
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id])

  @@id([variantId, attributeId])
  @@map("sku_variant_values")
}

model ProductImage {
  id        String   @id @default(uuid())
  skuId     String   @map("sku_id")
  url       String
  altText   String?  @map("alt_text")
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  sku SKU @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductBarcode {
  id          String   @id @default(uuid())
  skuId       String   @map("sku_id")
  barcode     String   @unique
  barcodeType String   @default("EAN13") @map("barcode_type")
  isDefault   Boolean  @default(false) @map("is_default")
  label       String?
  createdAt   DateTime @default(now()) @map("created_at")

  sku SKU @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@map("product_barcodes")
}

model Floor {
  id        String   @id @default(uuid())
  branchId  String   @map("branch_id")
  name      String
  code      String
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  branch           Branch          @relation(fields: [branchId], references: [id])
  racks            Rack[]
  shelves          Shelf[]
  boxes            StorageBox[]
  inventoryRecords InventoryRecord[]
  grns             GRN[]
  transfersFrom    StockTransfer[] @relation("StockTransferFromFloor")
  transfersTo      StockTransfer[] @relation("StockTransferToFloor")

  @@map("floors")
}

model Rack {
  id        String   @id @default(uuid())
  floorId   String   @map("floor_id")
  name      String
  code      String
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  // 3D layout position (metres) and rotation (degrees around Y axis)
  posX      Float?   @map("pos_x")
  posZ      Float?   @map("pos_z")
  rotY      Float?   @default(0) @map("rot_y")

  // Physical dimensions in cm
  widthCm   Float?   @map("width_cm")
  heightCm  Float?   @map("height_cm")
  depthCm   Float?   @map("depth_cm")

  floor   Floor   @relation(fields: [floorId], references: [id])
  shelves Shelf[]

  @@map("racks")
}

model Shelf {
  id            String   @id @default(uuid())
  floorId       String   @map("floor_id")
  rackId        String?  @map("rack_id")
  name          String
  code          String
  height        Float
  width         Float
  length        Float
  hasFreezer    Boolean  @default(false) @map("has_freezer")
  hasLock       Boolean  @default(false) @map("has_lock")
  notes         String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  floor            Floor            @relation(fields: [floorId], references: [id])
  rack             Rack?            @relation(fields: [rackId], references: [id])
  boxes            StorageBox[]
  inventoryRecords InventoryRecord[]

  @@map("shelves")
}

model StorageBox {
  id             String   @id @default(uuid())
  shelfId        String?  @map("shelf_id")
  floorId        String?  @map("floor_id")
  name           String
  code           String
  height         Float
  width          Float
  length         Float
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  // 3D position/orientation within its parent space (metres / degrees)
  posX           Float?   @map("pos_x")
  posY           Float?   @map("pos_y")
  posZ           Float?   @map("pos_z")
  rotationAngle  Float?   @default(0) @map("rotation_angle")

  // Stacking support
  stackOrder     Int?     @default(0) @map("stack_order")
  parentBoxId    String?  @map("parent_box_id")

  shelf            Shelf?           @relation(fields: [shelfId], references: [id])
  floor            Floor?           @relation(fields: [floorId], references: [id])
  parentBox        StorageBox?      @relation("BoxStacking", fields: [parentBoxId], references: [id])
  stackedBoxes     StorageBox[]     @relation("BoxStacking")
  barcodes         BoxBarcode[]
  inventoryRecords InventoryRecord[]

  @@map("storage_boxes")
}

model BoxBarcode {
  id          String   @id @default(uuid())
  boxId       String   @map("box_id")
  barcode     String   @unique
  barcodeType String   @default("EAN13") @map("barcode_type")
  isDefault   Boolean  @default(false) @map("is_default")
  label       String?
  createdAt   DateTime @default(now()) @map("created_at")

  box StorageBox @relation(fields: [boxId], references: [id], onDelete: Cascade)

  @@map("box_barcodes")
}

model StockTransfer {
  id               String    @id @default(uuid())
  referenceNumber  String    @unique @map("reference_number")
  fromBranchId     String?   @map("from_branch_id")
  toBranchId       String?   @map("to_branch_id")
  fromFloorId      String?   @map("from_floor_id")
  toFloorId        String?   @map("to_floor_id")
  status           String    @default("Draft")
  notes            String?
  requestedBy      String    @map("requested_by")
  approvedBy       String?   @map("approved_by")
  requestedAt      DateTime  @default(now()) @map("requested_at")
  approvedAt       DateTime? @map("approved_at")
  completedAt      DateTime? @map("completed_at")

  fromBranch   Branch?   @relation("StockTransferFrom", fields: [fromBranchId], references: [id])
  toBranch     Branch?   @relation("StockTransferTo", fields: [toBranchId], references: [id])
  fromFloor    Floor?    @relation("StockTransferFromFloor", fields: [fromFloorId], references: [id])
  toFloor      Floor?    @relation("StockTransferToFloor", fields: [toFloorId], references: [id])
  requester    User      @relation("StockTransferCreator", fields: [requestedBy], references: [id])
  approver     User?     @relation("StockTransferApprover", fields: [approvedBy], references: [id])
  lines        StockTransferLine[]

  @@map("stock_transfers")
}

model StockTransferLine {
  id               String @id @default(uuid())
  transferId       String @map("transfer_id")
  skuId            String @map("sku_id")
  requestedQty     Int    @map("requested_qty")
  transferredQty   Int    @default(0) @map("transferred_qty")
  notes            String?

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@map("stock_transfer_lines")
}

model InventoryRecord {
  id            String   @id @default(uuid())
  skuId         String   @map("sku_id")
  variantId     String?  @map("variant_id")
  batchId       String?  @map("batch_id")
  floorId       String?  @map("floor_id")
  shelfId       String?  @map("shelf_id")
  boxId         String?  @map("box_id")
  quantity      Int
  state         String
  sourceEventId String?  @map("source_event_id")
  terminalId    String?  @map("terminal_id")
  userId        String?  @map("user_id")
  version       Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sku      SKU         @relation(fields: [skuId], references: [id])
  variant  SKUVariant? @relation(fields: [variantId], references: [id])
  floor    Floor?      @relation(fields: [floorId], references: [id])
  shelf    Shelf?      @relation(fields: [shelfId], references: [id])
  box      StorageBox? @relation(fields: [boxId], references: [id])
  user     User?       @relation(fields: [userId], references: [id])

  @@map("inventory_records")
}

model InventoryEvent {
  id             String   @id @default(uuid())
  eventType      String   @map("event_type")
  parentEntityId String?  @map("parent_entity_id")
  quantityDelta  Int?     @map("quantity_delta")
  beforeQuantity Int?     @map("before_quantity")
  afterQuantity  Int?     @map("after_quantity")
  reasonCode     String?  @map("reason_code")
  userId         String?  @map("user_id")
  terminalId     String?  @map("terminal_id")
  timestamp      DateTime @default(now())
  overrideFlag   Boolean  @default(false) @map("override_flag")
  metadata       Json?

  user User? @relation(fields: [userId], references: [id])

  @@map("inventory_events")
}

model GRN {
  id                   String    @id @default(uuid())
  supplierId           String    @map("supplier_id")
  floorId              String?   @map("floor_id")
  invoiceReference     String?   @map("invoice_reference")
  supplierInvoiceDate  DateTime? @map("supplier_invoice_date")
  expectedDeliveryDate DateTime? @map("expected_delivery_date")
  deliveryDate         DateTime? @map("delivery_date")
  status               String    @default("Draft")
  notes                String?
  createdBy            String    @map("created_by")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  supplier Vendor    @relation(fields: [supplierId], references: [id])
  floor    Floor?    @relation(fields: [floorId], references: [id])
  creator  User      @relation(fields: [createdBy], references: [id])
  lines    GRNLine[]

  @@map("grns")
}

model GRNLine {
  id               String  @id @default(uuid())
  grnId            String  @map("grn_id")
  skuId            String  @map("sku_id")
  variantId        String? @map("variant_id")
  expectedQuantity Int     @map("expected_quantity")
  receivedQuantity Int     @default(0) @map("received_quantity")
  batchReference   String? @map("batch_reference")
  notes            String?

  grn               GRN                @relation(fields: [grnId], references: [id])
  sku               SKU                @relation(fields: [skuId], references: [id])
  variant           SKUVariant?        @relation(fields: [variantId], references: [id])
  inspectionRecords InspectionRecord[]

  @@map("grn_lines")
}

model InspectionRecord {
  id                   String   @id @default(uuid())
  grnLineId            String   @map("grn_line_id")
  approvedQuantity     Int      @map("approved_quantity")
  rejectedQuantity     Int      @map("rejected_quantity")
  damageClassification String?  @map("damage_classification")
  inspectorUserId      String   @map("inspector_user_id")
  timestamp            DateTime @default(now())
  remarks              String?

  grnLine   GRNLine @relation(fields: [grnLineId], references: [id])
  inspector User    @relation(fields: [inspectorUserId], references: [id])

  @@map("inspection_records")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  changes    Json?
  ipAddress  String?  @map("ip_address")
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model SyncQueue {
  id            String    @id @default(uuid())
  clientId      String    @map("client_id")
  operation     String
  payload       Json
  status        String    @default("Pending")
  createdAt     DateTime  @default(now()) @map("created_at")
  processedAt   DateTime? @map("processed_at")
  conflictFlag  Boolean   @default(false) @map("conflict_flag")
  conflictNotes String?   @map("conflict_notes")

  @@map("sync_queue")
}

model StatusOption {
  id         String   @id @default(uuid())
  entityType String   @map("entity_type")
  value      String
  label      String
  color      String?
  sortOrder  Int      @default(0) @map("sort_order")
  isDefault  Boolean  @default(false) @map("is_default")
  isSystem   Boolean  @default(false) @map("is_system")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([entityType, value])
  @@map("status_options")
}
