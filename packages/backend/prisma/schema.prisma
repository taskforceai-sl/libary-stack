generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String
  vendorId     String?  @map("vendor_id")
  createdAt    DateTime @default(now()) @map("created_at")
  isActive     Boolean  @default(true) @map("is_active")

  vendor                 Vendor?                @relation(fields: [vendorId], references: [id])
  inventoryRecords       InventoryRecord[]
  inventoryEvents        InventoryEvent[]
  grns                   GRN[]
  inspectionRecords      InspectionRecord[]
  auditLogs              AuditLog[]
  stockTransfersCreated  StockTransfer[]        @relation("StockTransferCreator")
  stockTransfersApproved StockTransfer[]        @relation("StockTransferApprover")

  @@map("users")
}

model Vendor {
  id           String   @id @default(uuid())
  name         String
  contactEmail String   @map("contact_email")
  contactPhone String?  @map("contact_phone")
  address      String?
  type         String   @default("Vendor") @map("type")
  website      String?
  taxId        String?  @map("tax_id")
  paymentTerms String?  @map("payment_terms")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  isActive     Boolean  @default(true) @map("is_active")

  users User[]
  skus  SKU[]
  grns  GRN[]

  @@map("vendors")
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  parentId    String?   @map("parent_id")
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  skus     SKU[]

  @@map("categories")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now()) @map("created_at")

  skus SKUTag[]

  @@map("tags")
}

model UnitOfMeasureModel {
  id           String   @id @default(uuid())
  name         String   @unique
  abbreviation String
  baseUnit     String?  @map("base_unit")
  conversionFactor Float? @map("conversion_factor")
  type         String
  isActive     Boolean  @default(true) @map("is_active")
  isSystem     Boolean  @default(false) @map("is_system")
  createdAt    DateTime @default(now()) @map("created_at")

  skus SKU[]

  @@map("units_of_measure")
}

model Branch {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  address     String?
  phone       String?
  email       String?
  isActive    Boolean  @default(true) @map("is_active")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")

  locations             Location[]
  stockTransfersFrom    StockTransfer[] @relation("StockTransferFrom")
  stockTransfersTo      StockTransfer[] @relation("StockTransferTo")

  @@map("branches")
}

model SKU {
  id              String   @id @default(uuid())
  skuCode         String   @unique @map("sku_code")
  name            String
  description     String?
  categoryId      String?  @map("category_id")
  vendorId        String   @map("vendor_id")
  unitOfMeasureId String?  @map("unit_of_measure_id")
  unitOfMeasure   String   @map("unit_of_measure")
  conversionRules Json?    @map("conversion_rules")
  dimensions      Json?
  isFragile       Boolean  @default(false) @map("is_fragile")
  maxStackHeight  Float?   @map("max_stack_height")
  batchPricing    Json?    @map("batch_pricing")
  lowStockThreshold Int?   @map("low_stock_threshold")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  vendor           Vendor              @relation(fields: [vendorId], references: [id])
  category         Category?           @relation(fields: [categoryId], references: [id])
  unitModel        UnitOfMeasureModel? @relation(fields: [unitOfMeasureId], references: [id])
  inventoryRecords InventoryRecord[]
  grnLines         GRNLine[]
  images           ProductImage[]
  barcodes         ProductBarcode[]
  tags             SKUTag[]

  @@map("skus")
}

model SKUTag {
  skuId String @map("sku_id")
  tagId String @map("tag_id")

  sku SKU @relation(fields: [skuId], references: [id], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([skuId, tagId])
  @@map("sku_tags")
}

model ProductImage {
  id        String   @id @default(uuid())
  skuId     String   @map("sku_id")
  url       String
  altText   String?  @map("alt_text")
  isPrimary Boolean  @default(false) @map("is_primary")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  sku SKU @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductBarcode {
  id          String   @id @default(uuid())
  skuId       String   @map("sku_id")
  barcode     String   @unique
  barcodeType String   @default("EAN13") @map("barcode_type")
  isDefault   Boolean  @default(false) @map("is_default")
  label       String?
  createdAt   DateTime @default(now()) @map("created_at")

  sku SKU @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@map("product_barcodes")
}

model Location {
  id              String  @id @default(uuid())
  branchId        String? @map("branch_id")
  floor           String
  section         String
  shelf           String
  zone            String?
  capacityCubicCm Float?  @map("capacity_cubic_cm")
  notes           String?
  isActive        Boolean @default(true) @map("is_active")

  branch           Branch?         @relation(fields: [branchId], references: [id])
  inventoryRecords InventoryRecord[]
  grns             GRN[]
  transfersFrom    StockTransfer[] @relation("StockTransferFromLocation")
  transfersTo      StockTransfer[] @relation("StockTransferToLocation")

  @@map("locations")
}

model StockTransfer {
  id               String    @id @default(uuid())
  referenceNumber  String    @unique @map("reference_number")
  fromBranchId     String?   @map("from_branch_id")
  toBranchId       String?   @map("to_branch_id")
  fromLocationId   String?   @map("from_location_id")
  toLocationId     String?   @map("to_location_id")
  status           String    @default("Draft")
  notes            String?
  requestedBy      String    @map("requested_by")
  approvedBy       String?   @map("approved_by")
  requestedAt      DateTime  @default(now()) @map("requested_at")
  approvedAt       DateTime? @map("approved_at")
  completedAt      DateTime? @map("completed_at")

  fromBranch   Branch?   @relation("StockTransferFrom", fields: [fromBranchId], references: [id])
  toBranch     Branch?   @relation("StockTransferTo", fields: [toBranchId], references: [id])
  fromLocation Location? @relation("StockTransferFromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location? @relation("StockTransferToLocation", fields: [toLocationId], references: [id])
  requester    User      @relation("StockTransferCreator", fields: [requestedBy], references: [id])
  approver     User?     @relation("StockTransferApprover", fields: [approvedBy], references: [id])
  lines        StockTransferLine[]

  @@map("stock_transfers")
}

model StockTransferLine {
  id               String @id @default(uuid())
  transferId       String @map("transfer_id")
  skuId            String @map("sku_id")
  requestedQty     Int    @map("requested_qty")
  transferredQty   Int    @default(0) @map("transferred_qty")
  notes            String?

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@map("stock_transfer_lines")
}

model InventoryRecord {
  id            String   @id @default(uuid())
  skuId         String   @map("sku_id")
  batchId       String?  @map("batch_id")
  locationId    String?  @map("location_id")
  quantity      Int
  state         String
  sourceEventId String?  @map("source_event_id")
  terminalId    String?  @map("terminal_id")
  userId        String?  @map("user_id")
  version       Int      @default(1)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sku      SKU       @relation(fields: [skuId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])

  @@map("inventory_records")
}

model InventoryEvent {
  id             String   @id @default(uuid())
  eventType      String   @map("event_type")
  parentEntityId String?  @map("parent_entity_id")
  quantityDelta  Int?     @map("quantity_delta")
  beforeQuantity Int?     @map("before_quantity")
  afterQuantity  Int?     @map("after_quantity")
  reasonCode     String?  @map("reason_code")
  userId         String?  @map("user_id")
  terminalId     String?  @map("terminal_id")
  timestamp      DateTime @default(now())
  overrideFlag   Boolean  @default(false) @map("override_flag")
  metadata       Json?

  user User? @relation(fields: [userId], references: [id])

  @@map("inventory_events")
}

model GRN {
  id                   String    @id @default(uuid())
  supplierId           String    @map("supplier_id")
  locationId           String?   @map("location_id")
  invoiceReference     String?   @map("invoice_reference")
  supplierInvoiceDate  DateTime? @map("supplier_invoice_date")
  expectedDeliveryDate DateTime? @map("expected_delivery_date")
  deliveryDate         DateTime? @map("delivery_date")
  status               String    @default("Draft")
  notes                String?
  createdBy            String    @map("created_by")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  supplier Vendor    @relation(fields: [supplierId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])
  creator  User      @relation(fields: [createdBy], references: [id])
  lines    GRNLine[]

  @@map("grns")
}

model GRNLine {
  id               String  @id @default(uuid())
  grnId            String  @map("grn_id")
  skuId            String  @map("sku_id")
  expectedQuantity Int     @map("expected_quantity")
  receivedQuantity Int     @default(0) @map("received_quantity")
  batchReference   String? @map("batch_reference")
  notes            String?

  grn               GRN                @relation(fields: [grnId], references: [id])
  sku               SKU                @relation(fields: [skuId], references: [id])
  inspectionRecords InspectionRecord[]

  @@map("grn_lines")
}

model InspectionRecord {
  id                   String   @id @default(uuid())
  grnLineId            String   @map("grn_line_id")
  approvedQuantity     Int      @map("approved_quantity")
  rejectedQuantity     Int      @map("rejected_quantity")
  damageClassification String?  @map("damage_classification")
  inspectorUserId      String   @map("inspector_user_id")
  timestamp            DateTime @default(now())
  remarks              String?

  grnLine   GRNLine @relation(fields: [grnLineId], references: [id])
  inspector User    @relation(fields: [inspectorUserId], references: [id])

  @@map("inspection_records")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  changes    Json?
  ipAddress  String?  @map("ip_address")
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model SyncQueue {
  id            String    @id @default(uuid())
  clientId      String    @map("client_id")
  operation     String
  payload       Json
  status        String    @default("Pending")
  createdAt     DateTime  @default(now()) @map("created_at")
  processedAt   DateTime? @map("processed_at")
  conflictFlag  Boolean   @default(false) @map("conflict_flag")
  conflictNotes String?   @map("conflict_notes")

  @@map("sync_queue")
}
