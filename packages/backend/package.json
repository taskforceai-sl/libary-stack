{
	"name": "@jingles/backend",
	"version": "1.0.0",
	"main": "dist/server.js",
	"scripts": {
		"dev": "ts-node-dev --respawn --transpile-only src/server.ts",
		"build": "prisma generate && tsc",
		"start": "node dist/server.js",
		"deploy": "prisma migrate deploy && prisma generate && tsc && pm2 restart jingles-backend",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate dev",
		"prisma:seed": "ts-node src/prisma/seed.ts",
		"prisma:seed-stress": "ts-node src/prisma/seed-stress.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"dependencies": {
		"@jingles/shared": "*",
		"@prisma/client": "^5.7.1",
		"bcryptjs": "^2.4.3",
		"cors": "^2.8.5",
		"dotenv": "^16.3.1",
		"express": "^4.18.2",
		"express-rate-limit": "^8.3.1",
		"express-validator": "^7.0.1",
		"jsonwebtoken": "^9.0.2",
		"multer": "^2.1.1",
		"uuid": "^9.0.0",
		"winston": "^3.11.0"
	},
	"devDependencies": {
		"@types/bcryptjs": "^2.4.6",
		"@types/cors": "^2.8.17",
		"@types/express": "^4.17.21",
		"@types/express-rate-limit": "^5.1.3",
		"@types/jsonwebtoken": "^9.0.5",
		"@types/multer": "^1.4.11",
		"@types/node": "^20.10.6",
		"@types/supertest": "^7.2.0",
		"@types/uuid": "^9.0.7",
		"@vitest/coverage-v8": "^4.1.0",
		"prisma": "^5.7.1",
		"supertest": "^7.2.2",
		"ts-node": "^10.9.2",
		"ts-node-dev": "^2.0.0",
		"typescript": "^5.3.3",
		"vitest": "^4.1.0"
	}
}