{
  "name": "@jingles/electron",
  "version": "1.0.0",
  "main": "dist/electron/main.js",
  "private": true,
  "scripts": {
    "dev": "concurrently \"tsc -w\" \"wait-on dist/electron/main.js && electron .\"",
    "build": "tsc",
    "build:electron": "electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "@jingles/shared": "*",
    "better-sqlite3": "^9.4.3",
    "axios": "^1.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "uuid": "^9.0.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.jingles.inventory",
    "productName": "Jingles Inventory",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.business"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
